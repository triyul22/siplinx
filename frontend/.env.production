# Прод-конфиг фронта (НЕ секрет — публичный URL). Коммитится в репо.
# next build (production, в т.ч. в CI/tauri-action) встраивает NEXT_PUBLIC_* в сборку.
# Без этого десктоп указывал бы на http://localhost:3210 (дефолт в src/config/auth.ts),
# т.к. frontend/.env в .gitignore и в CI отсутствует.
NEXT_PUBLIC_AUTH_URL=https://siplinx-ai.vercel.app
# Режим биллинга билда: trial (авто-триал 7 дней, дефолт) | direct (сразу оплата).
# CI переопределяет через env NEXT_PUBLIC_BILLING_MODE (env сильнее .env-файлов).
NEXT_PUBLIC_BILLING_MODE=trial
