{
  "name": "siplinx-auth-service",
  "version": "0.1.0",
  "private": true,
  "description": "Тонкий облачный сервис: Google-авторизация (Better Auth) + подписка Polar для десктопа Siplinx AI",
  "scripts": {
    "dev": "next dev -p 3210",
    "build": "next build",
    "start": "next start -p 3210",
    "auth:generate": "npx @better-auth/cli@latest generate --output ./better-auth_migrations",
    "auth:migrate": "npx @better-auth/cli@latest migrate"
  },
  "dependencies": {
    "@polar-sh/better-auth": "^1.8.4",
    "@polar-sh/sdk": "^0.47.0",
    "better-auth": "^1.6.18",
    "next": "^14.2.25",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "typescript": "^5.7.2"
  }
}
