# ============================================================
# Siplinx AI — auth-service. Скопируй в .env.local и заполни.
# ============================================================

# --- Сервис ---
# Сгенерируй: `openssl rand -base64 32`  (или любой 32+ символьный секрет)
BETTER_AUTH_SECRET=
# Публичный URL сервиса. Локально — как ниже; в проде — https://auth.siplinx.ai
BETTER_AUTH_URL=http://localhost:3210
NEXT_PUBLIC_AUTH_URL=http://localhost:3210

# --- Postgres (Neon / Vercel Postgres / Supabase) ---
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# --- Google OAuth (тип клиента: Web application) ---
# Authorized redirect URI в Google Console:
#   http://localhost:3210/api/auth/callback/google   (dev)
#   https://auth.siplinx.ai/api/auth/callback/google  (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Polar ---
# Organization Access Token (Settings → API Tokens). НЕ публикуй.
POLAR_ACCESS_TOKEN=
# Webhook signing secret (Settings → Webhooks → endpoint .../api/auth/polar/webhooks)
POLAR_WEBHOOK_SECRET=
# sandbox для тестов, production для боевого режима
POLAR_SERVER=sandbox
# ID продуктов подписки из Polar (Products → product → ID).
# MONTHLY = тариф 1: $2/неделю, без триала (продукт с интервалом week).
POLAR_PRODUCT_ID_MONTHLY=
POLAR_PRODUCT_ID_YEARLY=
# TRIAL7 = тариф 2: 7 дней бесплатно, затем $4/неделю (продукт с интервалом week).
# Триал навешивается на чекауте (TRIAL_DAYS), на продукте настраивать не нужно.
POLAR_PRODUCT_ID_TRIAL7=
TRIAL_DAYS=7

# --- Безопасность desktop loopback ---
# Десктоп поднимает временный сервер на 127.0.0.1:<порт> для приёма токена.
# Разрешённый диапазон портов (защита от open-redirect).
DESKTOP_LOOPBACK_PORT_MIN=38400
DESKTOP_LOOPBACK_PORT_MAX=38500

# --- CORS (origin десктопа). Для отладки можно "*", в проде сузить. ---
CORS_ALLOW_ORIGIN=*

# --- AI APIs ---
# OpenAI используется server-side для /api/summary и /api/chat.
OPENAI_API_KEY=
# Опционально: можно сменить модель без правки кода.
OPENAI_SUMMARY_MODEL=gpt-5.4-mini
OPENAI_CHAT_MODEL=gpt-5.4-mini
CHAT_DAILY_LIMIT=4

# --- Email-рассылки (Resend) ---
# API-ключ Resend (Dashboard → API Keys). Без него письма не шлются (dev-режим).
RESEND_API_KEY=
# От кого и куда отвечать. Домен должен быть верифицирован в Resend (SPF/DKIM/DMARC).
EMAIL_FROM=Julia from Siplinx <julia@mail.siplinx.ai>
EMAIL_REPLY_TO=julia@siplinx.ai
# Куда ведут кнопки в письмах. Реальная покупка/промокод — внутри приложения,
# поэтому по умолчанию ведём на сайт; можно заменить на deep link (siplinx://open).
EMAIL_SITE_URL=https://siplinx.ai
EMAIL_APP_URL=
# Секрет для подписи ссылок отписки (HMAC). Если пусто — берётся BETTER_AUTH_SECRET.
EMAIL_UNSUB_SECRET=
# Секрет вебхука Resend: если задан, /api/email/webhook требует ?secret=<это>.
RESEND_WEBHOOK_SECRET=
# Секрет cron: Vercel Cron сам шлёт Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=

# --- Реферальная программа (блогеры через Afluencer) ---
# Дефолтная ставка комиссии, % от каждого списания trial7-продукта.
REFERRAL_COMMISSION_PCT=50
# Секрет админ-эндпоинтов /api/referral/* (Authorization: Bearer <это>).
# Не задан = админ-эндпоинты отдают 503. Тот же секрет подписывает
# токены страниц статистики /partner/<code>.
REFERRAL_ADMIN_SECRET=
